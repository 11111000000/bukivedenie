{"sentence_index": 0, "start_offset": 0, "end_offset": 39, "tokens": [{"text": "Глава", "start": 0, "end": 5, "is_first": true}, {"text": "Это", "start": 9, "end": 12, "is_first": false}, {"text": "был", "start": 13, "end": 16, "is_first": false}, {"text": "обычный", "start": 17, "end": 24, "is_first": false}, {"text": "осенний", "start": 25, "end": 32, "is_first": false}, {"text": "день", "start": 33, "end": 37, "is_first": false}], "text": "Глава 1\n\nЭто был обычный осенний день. "}
{"sentence_index": 1, "start_offset": 39, "end_offset": 92, "tokens": [{"text": "Листья", "start": 39, "end": 45, "is_first": true}, {"text": "падали", "start": 46, "end": 52, "is_first": false}, {"text": "с", "start": 53, "end": 54, "is_first": false}, {"text": "деревьев", "start": 55, "end": 63, "is_first": false}, {"text": "и", "start": 65, "end": 66, "is_first": false}, {"text": "ветер", "start": 67, "end": 72, "is_first": false}, {"text": "gently", "start": 73, "end": 79, "is_first": false}, {"text": "дул", "start": 80, "end": 83, "is_first": false}, {"text": "в", "start": 84, "end": 85, "is_first": false}, {"text": "лицо", "start": 86, "end": 90, "is_first": false}], "text": "Листья падали с деревьев, и ветер gently дул в лицо. "}
{"sentence_index": 2, "start_offset": 92, "end_offset": 128, "tokens": [{"text": "Иван", "start": 92, "end": 96, "is_first": true}, {"text": "шёл", "start": 97, "end": 100, "is_first": false}, {"text": "по", "start": 101, "end": 103, "is_first": false}, {"text": "улице", "start": 104, "end": 109, "is_first": false}, {"text": "и", "start": 110, "end": 111, "is_first": false}, {"text": "думал", "start": 112, "end": 117, "is_first": false}, {"text": "о", "start": 118, "end": 119, "is_first": false}, {"text": "своём", "start": 120, "end": 125, "is_first": false}], "text": "Иван шёл по улице и думал о своём.\n\n"}
{"sentence_index": 3, "start_offset": 128, "end_offset": 144, "tokens": [{"text": "Привет", "start": 130, "end": 136, "is_first": false}, {"text": "Иван", "start": 138, "end": 142, "is_first": false}], "text": "— Привет, Иван! "}
{"sentence_index": 4, "start_offset": 144, "end_offset": 165, "tokens": [{"text": "окликнул", "start": 146, "end": 154, "is_first": false}, {"text": "его", "start": 155, "end": 158, "is_first": false}, {"text": "Петр", "start": 159, "end": 163, "is_first": false}], "text": "— окликнул его Петр.\n"}
{"sentence_index": 5, "start_offset": 165, "end_offset": 185, "tokens": [{"text": "Здравствуй", "start": 167, "end": 177, "is_first": false}, {"text": "Петр", "start": 179, "end": 183, "is_first": false}], "text": "— Здравствуй, Петр. "}
{"sentence_index": 6, "start_offset": 185, "end_offset": 195, "tokens": [{"text": "Как", "start": 185, "end": 188, "is_first": true}, {"text": "дела", "start": 189, "end": 193, "is_first": false}], "text": "Как дела?\n"}
{"sentence_index": 7, "start_offset": 195, "end_offset": 214, "tokens": [{"text": "Хорошо", "start": 197, "end": 203, "is_first": false}, {"text": "спасибо", "start": 205, "end": 212, "is_first": false}], "text": "— Хорошо, спасибо. "}
{"sentence_index": 8, "start_offset": 214, "end_offset": 226, "tokens": [{"text": "Куда", "start": 214, "end": 218, "is_first": true}, {"text": "идёшь", "start": 219, "end": 224, "is_first": false}], "text": "Куда идёшь?\n"}
{"sentence_index": 9, "start_offset": 226, "end_offset": 242, "tokens": [{"text": "Просто", "start": 228, "end": 234, "is_first": false}, {"text": "гуляю", "start": 235, "end": 240, "is_first": false}], "text": "— Просто гуляю. "}
{"sentence_index": 10, "start_offset": 242, "end_offset": 259, "tokens": [{"text": "Осень", "start": 242, "end": 247, "is_first": true}, {"text": "красивая", "start": 248, "end": 256, "is_first": false}], "text": "Осень красивая.\n\n"}
{"sentence_index": 11, "start_offset": 259, "end_offset": 286, "tokens": [{"text": "Они", "start": 259, "end": 262, "is_first": true}, {"text": "пошли", "start": 263, "end": 268, "is_first": false}, {"text": "вместе", "start": 269, "end": 275, "is_first": false}, {"text": "по", "start": 276, "end": 278, "is_first": false}, {"text": "аллее", "start": 279, "end": 284, "is_first": false}], "text": "Они пошли вместе по аллее. "}
{"sentence_index": 12, "start_offset": 286, "end_offset": 319, "tokens": [{"text": "Разговор", "start": 286, "end": 294, "is_first": true}, {"text": "был", "start": 295, "end": 298, "is_first": false}, {"text": "лёгким", "start": 299, "end": 305, "is_first": false}, {"text": "и", "start": 306, "end": 307, "is_first": false}, {"text": "приятным", "start": 308, "end": 316, "is_first": false}], "text": "Разговор был лёгким и приятным.\n\n"}
{"sentence_index": 13, "start_offset": 319, "end_offset": 367, "tokens": [{"text": "Глава", "start": 319, "end": 324, "is_first": true}, {"text": "На", "start": 328, "end": 330, "is_first": false}, {"text": "следующий", "start": 331, "end": 340, "is_first": false}, {"text": "день", "start": 341, "end": 345, "is_first": false}, {"text": "Иван", "start": 346, "end": 350, "is_first": false}, {"text": "проснулся", "start": 351, "end": 360, "is_first": false}, {"text": "рано", "start": 361, "end": 365, "is_first": false}], "text": "Глава 2\n\nНа следующий день Иван проснулся рано. "}
{"sentence_index": 14, "start_offset": 367, "end_offset": 411, "tokens": [{"text": "Солнце", "start": 367, "end": 373, "is_first": true}, {"text": "ещё", "start": 374, "end": 377, "is_first": false}, {"text": "не", "start": 378, "end": 380, "is_first": false}, {"text": "встало", "start": 381, "end": 387, "is_first": false}, {"text": "но", "start": 389, "end": 391, "is_first": false}, {"text": "небо", "start": 392, "end": 396, "is_first": false}, {"text": "уже", "start": 397, "end": 400, "is_first": false}, {"text": "светлело", "start": 401, "end": 409, "is_first": false}], "text": "Солнце ещё не встало, но небо уже светлело. "}
{"sentence_index": 15, "start_offset": 411, "end_offset": 450, "tokens": [{"text": "Он", "start": 411, "end": 413, "is_first": true}, {"text": "вышел", "start": 414, "end": 419, "is_first": false}, {"text": "из", "start": 420, "end": 422, "is_first": false}, {"text": "дома", "start": 423, "end": 427, "is_first": false}, {"text": "и", "start": 428, "end": 429, "is_first": false}, {"text": "направился", "start": 430, "end": 440, "is_first": false}, {"text": "к", "start": 441, "end": 442, "is_first": false}, {"text": "реке", "start": 443, "end": 447, "is_first": false}], "text": "Он вышел из дома и направился к реке.\n\n"}
{"sentence_index": 16, "start_offset": 450, "end_offset": 471, "tokens": [{"text": "Река", "start": 450, "end": 454, "is_first": true}, {"text": "была", "start": 455, "end": 459, "is_first": false}, {"text": "спокойной", "start": 460, "end": 469, "is_first": false}], "text": "Река была спокойной. "}
{"sentence_index": 17, "start_offset": 471, "end_offset": 505, "tokens": [{"text": "Вода", "start": 471, "end": 475, "is_first": true}, {"text": "отражала", "start": 476, "end": 484, "is_first": false}, {"text": "первые", "start": 485, "end": 491, "is_first": false}, {"text": "лучи", "start": 492, "end": 496, "is_first": false}, {"text": "солнца", "start": 497, "end": 503, "is_first": false}], "text": "Вода отражала первые лучи солнца. "}
{"sentence_index": 18, "start_offset": 505, "end_offset": 557, "tokens": [{"text": "Иван", "start": 505, "end": 509, "is_first": true}, {"text": "сел", "start": 510, "end": 513, "is_first": false}, {"text": "на", "start": 514, "end": 516, "is_first": false}, {"text": "скамейку", "start": 517, "end": 525, "is_first": false}, {"text": "и", "start": 526, "end": 527, "is_first": false}, {"text": "стал", "start": 528, "end": 532, "is_first": false}, {"text": "наблюдать", "start": 533, "end": 542, "is_first": false}, {"text": "за", "start": 543, "end": 545, "is_first": false}, {"text": "природой", "start": 546, "end": 554, "is_first": false}], "text": "Иван сел на скамейку и стал наблюдать за природой.\n\n"}
{"sentence_index": 19, "start_offset": 557, "end_offset": 585, "tokens": [{"text": "Ты", "start": 559, "end": 561, "is_first": false}, {"text": "тоже", "start": 562, "end": 566, "is_first": false}, {"text": "любишь", "start": 567, "end": 573, "is_first": false}, {"text": "это", "start": 574, "end": 577, "is_first": false}, {"text": "место", "start": 578, "end": 583, "is_first": false}], "text": "— Ты тоже любишь это место? "}
{"sentence_index": 20, "start_offset": 585, "end_offset": 613, "tokens": [{"text": "спросил", "start": 587, "end": 594, "is_first": false}, {"text": "незнакомый", "start": 595, "end": 605, "is_first": false}, {"text": "голос", "start": 606, "end": 611, "is_first": false}], "text": "— спросил незнакомый голос.\n"}
{"sentence_index": 21, "start_offset": 613, "end_offset": 629, "tokens": [{"text": "Иван", "start": 613, "end": 617, "is_first": true}, {"text": "обернулся", "start": 618, "end": 627, "is_first": false}], "text": "Иван обернулся. "}
{"sentence_index": 22, "start_offset": 629, "end_offset": 668, "tokens": [{"text": "Рядом", "start": 629, "end": 634, "is_first": true}, {"text": "стояла", "start": 635, "end": 641, "is_first": false}, {"text": "девушка", "start": 642, "end": 649, "is_first": false}, {"text": "с", "start": 650, "end": 651, "is_first": false}, {"text": "книгой", "start": 652, "end": 658, "is_first": false}, {"text": "в", "start": 659, "end": 660, "is_first": false}, {"text": "руках", "start": 661, "end": 666, "is_first": false}], "text": "Рядом стояла девушка с книгой в руках.\n"}
{"sentence_index": 23, "start_offset": 668, "end_offset": 681, "tokens": [{"text": "Да", "start": 670, "end": 672, "is_first": false}, {"text": "очень", "start": 674, "end": 679, "is_first": false}], "text": "— Да, очень. "}
{"sentence_index": 24, "start_offset": 681, "end_offset": 691, "tokens": [{"text": "А", "start": 681, "end": 682, "is_first": true}, {"text": "ты", "start": 683, "end": 685, "is_first": false}, {"text": "кто", "start": 686, "end": 689, "is_first": false}], "text": "А ты кто?\n"}
{"sentence_index": 25, "start_offset": 691, "end_offset": 710, "tokens": [{"text": "Меня", "start": 693, "end": 697, "is_first": false}, {"text": "зовут", "start": 698, "end": 703, "is_first": false}, {"text": "Анна", "start": 704, "end": 708, "is_first": false}], "text": "— Меня зовут Анна. "}
{"sentence_index": 26, "start_offset": 710, "end_offset": 726, "tokens": [{"text": "Я", "start": 710, "end": 711, "is_first": true}, {"text": "здесь", "start": 712, "end": 717, "is_first": false}, {"text": "новая", "start": 718, "end": 723, "is_first": false}], "text": "Я здесь новая.\n\n"}
{"sentence_index": 27, "start_offset": 726, "end_offset": 745, "tokens": [{"text": "Они", "start": 726, "end": 729, "is_first": true}, {"text": "разговорились", "start": 730, "end": 743, "is_first": false}], "text": "Они разговорились. "}
{"sentence_index": 28, "start_offset": 745, "end_offset": 785, "tokens": [{"text": "Анна", "start": 745, "end": 749, "is_first": true}, {"text": "оказалась", "start": 750, "end": 759, "is_first": false}, {"text": "интересным", "start": 760, "end": 770, "is_first": false}, {"text": "собеседником", "start": 771, "end": 783, "is_first": false}], "text": "Анна оказалась интересным собеседником. "}
{"sentence_index": 29, "start_offset": 785, "end_offset": 829, "tokens": [{"text": "Они", "start": 785, "end": 788, "is_first": true}, {"text": "говорили", "start": 789, "end": 797, "is_first": false}, {"text": "о", "start": 798, "end": 799, "is_first": false}, {"text": "книгах", "start": 800, "end": 806, "is_first": false}, {"text": "о", "start": 808, "end": 809, "is_first": false}, {"text": "природе", "start": 810, "end": 817, "is_first": false}, {"text": "о", "start": 819, "end": 820, "is_first": false}, {"text": "жизни", "start": 821, "end": 826, "is_first": false}], "text": "Они говорили о книгах, о природе, о жизни.\n\n"}
{"sentence_index": 30, "start_offset": 829, "end_offset": 863, "tokens": [{"text": "Глава", "start": 829, "end": 834, "is_first": true}, {"text": "Прошло", "start": 838, "end": 844, "is_first": false}, {"text": "несколько", "start": 845, "end": 854, "is_first": false}, {"text": "недель", "start": 855, "end": 861, "is_first": false}], "text": "Глава 3\n\nПрошло несколько недель. "}
{"sentence_index": 31, "start_offset": 863, "end_offset": 900, "tokens": [{"text": "Иван", "start": 863, "end": 867, "is_first": true}, {"text": "и", "start": 868, "end": 869, "is_first": false}, {"text": "Анна", "start": 870, "end": 874, "is_first": false}, {"text": "стали", "start": 875, "end": 880, "is_first": false}, {"text": "часто", "start": 881, "end": 886, "is_first": false}, {"text": "встречаться", "start": 887, "end": 898, "is_first": false}], "text": "Иван и Анна стали часто встречаться. "}
{"sentence_index": 32, "start_offset": 900, "end_offset": 968, "tokens": [{"text": "Они", "start": 900, "end": 903, "is_first": true}, {"text": "гуляли", "start": 904, "end": 910, "is_first": false}, {"text": "по", "start": 911, "end": 913, "is_first": false}, {"text": "городу", "start": 914, "end": 920, "is_first": false}, {"text": "ходили", "start": 922, "end": 928, "is_first": false}, {"text": "в", "start": 929, "end": 930, "is_first": false}, {"text": "музеи", "start": 931, "end": 936, "is_first": false}, {"text": "обсуждали", "start": 938, "end": 947, "is_first": false}, {"text": "прочитанные", "start": 948, "end": 959, "is_first": false}, {"text": "книги", "start": 960, "end": 965, "is_first": false}], "text": "Они гуляли по городу, ходили в музеи, обсуждали прочитанные книги.\n\n"}
{"sentence_index": 33, "start_offset": 968, "end_offset": 1024, "tokens": [{"text": "Петр", "start": 968, "end": 972, "is_first": true}, {"text": "заметил", "start": 973, "end": 980, "is_first": false}, {"text": "изменения", "start": 981, "end": 990, "is_first": false}, {"text": "в", "start": 991, "end": 992, "is_first": false}, {"text": "друге", "start": 993, "end": 998, "is_first": false}, {"text": "Ты", "start": 1002, "end": 1004, "is_first": false}, {"text": "стал", "start": 1005, "end": 1009, "is_first": false}, {"text": "другим", "start": 1010, "end": 1016, "is_first": false}, {"text": "Иван", "start": 1018, "end": 1022, "is_first": false}], "text": "Петр заметил изменения в друге:\n— Ты стал другим, Иван. "}
{"sentence_index": 34, "start_offset": 1024, "end_offset": 1039, "tokens": [{"text": "Что", "start": 1024, "end": 1027, "is_first": true}, {"text": "случилось", "start": 1028, "end": 1037, "is_first": false}], "text": "Что случилось?\n"}
{"sentence_index": 35, "start_offset": 1039, "end_offset": 1098, "tokens": [{"text": "Я", "start": 1041, "end": 1042, "is_first": false}, {"text": "встретил", "start": 1043, "end": 1051, "is_first": false}, {"text": "человека", "start": 1052, "end": 1060, "is_first": false}, {"text": "который", "start": 1062, "end": 1069, "is_first": false}, {"text": "изменил", "start": 1070, "end": 1077, "is_first": false}, {"text": "мой", "start": 1078, "end": 1081, "is_first": false}, {"text": "взгляд", "start": 1082, "end": 1088, "is_first": false}, {"text": "на", "start": 1089, "end": 1091, "is_first": false}, {"text": "вещи", "start": 1092, "end": 1096, "is_first": false}], "text": "— Я встретил человека, который изменил мой взгляд на вещи.\n"}
{"sentence_index": 36, "start_offset": 1098, "end_offset": 1110, "tokens": [{"text": "Это", "start": 1100, "end": 1103, "is_first": false}, {"text": "Анна", "start": 1104, "end": 1108, "is_first": false}], "text": "— Это Анна?\n"}
{"sentence_index": 37, "start_offset": 1110, "end_offset": 1122, "tokens": [{"text": "Да", "start": 1112, "end": 1114, "is_first": false}, {"text": "она", "start": 1116, "end": 1119, "is_first": false}], "text": "— Да, она.\n\n"}
{"sentence_index": 38, "start_offset": 1122, "end_offset": 1141, "tokens": [{"text": "Иван", "start": 1122, "end": 1126, "is_first": true}, {"text": "был", "start": 1127, "end": 1130, "is_first": false}, {"text": "счастлив", "start": 1131, "end": 1139, "is_first": false}], "text": "Иван был счастлив. "}
{"sentence_index": 39, "start_offset": 1141, "end_offset": 1191, "tokens": [{"text": "Осень", "start": 1141, "end": 1146, "is_first": true}, {"text": "сменилась", "start": 1147, "end": 1156, "is_first": false}, {"text": "зимой", "start": 1157, "end": 1162, "is_first": false}, {"text": "но", "start": 1164, "end": 1166, "is_first": false}, {"text": "в", "start": 1167, "end": 1168, "is_first": false}, {"text": "его", "start": 1169, "end": 1172, "is_first": false}, {"text": "душе", "start": 1173, "end": 1177, "is_first": false}, {"text": "было", "start": 1178, "end": 1182, "is_first": false}, {"text": "тепло", "start": 1183, "end": 1188, "is_first": false}], "text": "Осень сменилась зимой, но в его душе было тепло.\n\n"}
{"sentence_index": 40, "start_offset": 1191, "end_offset": 1198, "tokens": [{"text": "Конец", "start": 1191, "end": 1196, "is_first": true}], "text": "Конец.\n"}
